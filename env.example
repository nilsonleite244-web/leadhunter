# ─── BANCO DE DADOS (Supabase) ─────────────────────────────────────────────────
# Pegue em: supabase.com → seu projeto → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.[SEU-ID].supabase.co:5432/postgres

# ─── EVOLUTION API (WhatsApp self-hosted) ──────────────────────────────────────
# Após subir a Evolution API no Railway, coloque a URL aqui
EVOLUTION_URL=https://sua-evolution-api.railway.app
EVOLUTION_KEY=sua-api-key-aqui
EVOLUTION_INSTANCE=leadhunter

# ─── RESEND (Email gratuito) ───────────────────────────────────────────────────
# Cadastre em resend.com, plano gratuito = 3.000 emails/mês
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=contato@seudominio.com.br

# ─── CONFIGURAÇÕES ANTI-BAN WHATSAPP ──────────────────────────────────────────
WPP_LIMITE_DIARIO=100    # máximo de mensagens por dia (aumente gradualmente)
WPP_DELAY_MIN=30000      # delay mínimo entre mensagens em ms (30s)
WPP_DELAY_MAX=90000      # delay máximo entre mensagens em ms (90s)
WPP_HORA_INICIO=9        # hora de início dos envios (9h)
WPP_HORA_FIM=19          # hora de fim dos envios (19h)

# ─── API ───────────────────────────────────────────────────────────────────────
PORT=3000
API_SECRET=gere-uma-chave-secreta-forte-aqui

# ─── KIRVANO (Pagamentos) ───────────────────────────────────────────────────────
# URL do seu produto na Kirvano (ex: https://kirvano.com/checkout/seu-produto)
KIRVANO_CHECKOUT_URL=https://kirvano.com/checkout/seu-produto
